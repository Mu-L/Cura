checks:
    diagnostic-mesh-file-extension: true
    diagnostic-mesh-file-size: true
    # Temporarily disabled: the slice-time estimation engine depends on certain
    # override values being explicitly present even when they match the parent
    # definition. Re-enable once the engine no longer relies on those overrides.
    diagnostic-definition-redundant-override: false
    diagnostic-definition-experimental-setting: true
    diagnostic-resources-macos-app-directory-name: true
    diagnostic-incorrect-formula: true
    diagnostic-resource-file-deleted: true
    diagnostic-material-temperature-defined: false
    diagnostic-long-profile-names: true
    diagnostic-circular-dependency: true
fixes:
    diagnostic-definition-redundant-override: true
format:
    format-definition-bracket-newline: true
    format-definition-paired-coordinate-array: true
    format-definition-sort-keys: true
    format-definition-indent: 4
    format-definition-single-value-single-line: true # Format dicts and lists with a single item on one line "dict": { "value": 10 }
    format-profile-space-around-delimiters: true
    format-profile-sort-keys: true
diagnostic-mesh-file-size: 1200000
diagnostic-definition-redundant-override-ignore:
  - machine_.*
