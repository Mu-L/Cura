# -*- mode: python ; coding: utf-8 -*-
import os
from pathlib import Path
from PyInstaller.utils.hooks import collect_all


datas = {{ datas }}
binaries = {{ binaries }}

hiddenimports = {{ hiddenimports }}

{% for value in collect_all %}tmp_ret = collect_all('{{ value }}')
datas += tmp_ret[0]; binaries += tmp_ret[1]; hiddenimports += tmp_ret[2]
{% endfor %}

# Add dynamic libs in the venv bin/Script Path. This is needed because we might copy some additional libs
# e.q.: OpenSSL 1.1.1l in that directory with a separate:
# `conan install openssl@1.1.1l -g deploy && cp openssl/bin/*.so cura_inst/bin`
binaries.extend([(str(bin), ".") for bin in Path(r"{{ venv_script_path }}").glob("*.so*")])
binaries.extend([(str(bin), ".") for bin in Path(r"{{ venv_script_path }}").glob("*.dll")])
binaries.extend([(str(bin), ".") for bin in Path(r"{{ venv_script_path }}").glob("*.dylib")])

block_cipher = None

# Modules excluded from the build. These are unused by Cura.
# This filter runs after PyInstaller's Analysis phase, so it covers libraries discovered through
# PyQt6's own bundled Qt copies as well as anything pulled in via Conan.
# The conandata.yml blacklist handles the same set at the Conan-deploy stage; keeping both ensures
# nothing slips through regardless of which path the library entered the bundle from.
import re as _re

# Matches Qt6 shared-library file names (e.g. libQt6Multimedia.so.6, Qt6Multimedia.dll)
_QT_EXCL_LIB = _re.compile(
    r"qt6bluetooth|qt6designer|qt6help|qt6nfc|qt6printsupport|qt6serialport"
    r"|qt6spatialaudio|qt6sql|qt6test|qt6quicktest|qt6quicktimeline"
    r"|qt6texttospeech|qt6webchannel|qt6websockets"
    r"|qt6labsfolderlistmodel|qt6labsplatform|qt6labssettings|qt6labsqmlmodels"
    r"|qt6labssharedimage|qt6labswavefrontmesh"
    r"|qt6quickparticles|qt6quickvectorimage"
    r"|qt6quick3dxr|qt6quick3dphysics|qt6quick3dspatialaudio"
    r"|qt6multimedia|qt6pdf|qt6positioning|qt6remoteobjects|qt6sensors|qt6statemachine"
    r"|libavcodec|libavformat|libavutil|libswresample|libswscale",
    _re.IGNORECASE,
)

# Matches QML module directory path segments (no Qt6 prefix in dir names).
# Used to strip the accompanying QML imports for the libraries excluded above.
_QT_EXCL_PATH = _re.compile(
    r"[/\\]QtMultimedia[/\\]|[/\\]QtPositioning[/\\]|[/\\]QtRemoteObjects[/\\]"
    r"|[/\\]QtSensors[/\\]|[/\\]QtStateMachine[/\\]|[/\\]QtTextToSpeech[/\\]"
    r"|[/\\]QtWebChannel[/\\]|[/\\]QtWebSockets[/\\]"
    r"|[/\\]QtQuick3D[/\\]Xr(?:[/\\]|$)|[/\\]QtQuick3D[/\\]Physics[/\\]"
    r"|[/\\]QtQuick3D[/\\]SpatialAudio[/\\]"
    r"|[/\\]QtQuick[/\\]Timeline[/\\]|[/\\]QtQuick[/\\]Particles[/\\]"
    r"|[/\\]QtQuick[/\\]VectorImage[/\\]|[/\\]QtQuick[/\\]Pdf[/\\]",
    _re.IGNORECASE,
)

a = Analysis(
    [{{ entrypoint }}],
    pathex=[],
    binaries=binaries,
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=["Cura-workflows/runner_scripts/pyinstaller_hooks"],
    hooksconfig={},
    runtime_hooks=[],
    excludes=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False
)

# Filter unused Qt modules from all sources (Conan + PyQt6-bundled).
a.binaries = TOC([(n, p, t) for n, p, t in a.binaries
                   if not _QT_EXCL_LIB.search(p or n) and not _QT_EXCL_PATH.search(p or n)])
a.datas    = TOC([(n, p, t) for n, p, t in a.datas
                   if not _QT_EXCL_LIB.search(p or n) and not _QT_EXCL_PATH.search(p or n)])

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name=r'{{ name }}',
    debug=False,
    bootloader_ignore_signals=False,
    strip={{ strip }},
    upx={{ upx }},
    console=False,
    disable_windowed_traceback=False,
    argv_emulation=False,
    target_arch={{ target_arch }},
    codesign_identity=os.getenv('CODESIGN_IDENTITY', None),
    entitlements_file={{ entitlements_file }},
    icon={{ icon }},
    contents_directory='.'
)

coll = COLLECT(
    exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=True,
    upx_exclude=[],
    name=r'{{ name }}'
)

{% if macos == true %}
app = BUNDLE(
    coll,
    name='{{ display_name }}.app',
    icon={{ icon }},
    bundle_identifier={{ osx_bundle_identifier }} + "_" + '{{ display_name }}'.replace(" ", "_"),
    version={{ version }},
    info_plist={
        'CFBundleDisplayName': '{{ display_name }}',
        'NSPrincipalClass': 'NSApplication',
        'CFBundleDevelopmentRegion': 'English',
        'CFBundleExecutable': '{{ name }}',
        'CFBundleInfoDictionaryVersion': '6.0',
        'CFBundlePackageType': 'APPL',
        'CFBundleVersionString': {{ version }},
        'CFBundleShortVersionString': {{ short_version }},
        'CFBundleURLTypes': [{
                'CFBundleURLName': '{{ display_name }}',
                'CFBundleURLSchemes': ['cura', 'slicer'],
        }],
        'CFBundleDocumentTypes': [{
            'CFBundleTypeRole': 'Viewer',
            'CFBundleTypeExtensions': ['stl', 'obj', '3mf', 'gcode', 'ufp'],
            'CFBundleTypeName': 'Model Files',
        }]
    },
)
{% endif %}
